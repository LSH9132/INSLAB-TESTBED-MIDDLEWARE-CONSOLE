PORT=3001
DB_PATH=./data/central.sqlite
SSH_PRIVATE_KEY_PATH=~/.ssh/id_rsa
LOG_SERVER_URL=http://localhost:3002
PUBLIC_LOG_SERVER_HOST=127.0.0.1
PUBLIC_LOG_SERVER_TCP_PORT=6140
NET_AGENT_SHARED_SECRET=change-me-net-agent-secret
NET_AGENT_TOKEN_TTL_SEC=604800
NET_AGENT_PROTOCOL_VERSION=1
MIN_NET_AGENT_VERSION=0.2.0
RECOMMENDED_NET_AGENT_VERSION=0.2.0
NET_STATS_POLL_INTERVAL_MS=5000
NET_STATS_FRESHNESS_MS=30000
NET_AGENT_CLOCK_SYNC_INTERVAL_MS=900000
